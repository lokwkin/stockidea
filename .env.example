# Financial Modeling Prep API key (required)
FMP_API_KEY=<FMP_API_KEY>

# AI Agent — at least one is required
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>
OPENAI_API_KEY=<OPENAI_API_KEY>

# PostgreSQL configuration (optional when using docker-compose, required for local development)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stockidea
POSTGRES_USER=stockidea_user
POSTGRES_PASSWORD=stockidea_password

# Telegram bot (required only when running `stockidea telegram run-bot`)
TELEGRAM_BOT_TOKEN=<TELEGRAM_BOT_TOKEN>
TELEGRAM_CHAT_ID=<TELEGRAM_CHAT_ID>

# Strategy used by the bot's /pick command
STRATEGY_RULE=
STRATEGY_SORT=
STRATEGY_MAX_STOCKS=3
STRATEGY_INDEX=SP500
# At most one of the two stop-loss vars should be set.
STRATEGY_STOP_LOSS_PCT=
STRATEGY_STOP_LOSS_MA=